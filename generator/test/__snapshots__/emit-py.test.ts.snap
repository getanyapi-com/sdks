"""Generated namespace module for the facebook platform."""

from __future__ import annotations

from typing import Literal, TYPE_CHECKING

from pydantic import BaseModel, ConfigDict, Field
from typing_extensions import NotRequired, Required, TypedDict, Unpack

from ..types import RequestOptions, RunResult
from .._pagination import (
    AsyncPaginator,
    Paginator,
    apaginate,
    paginate,
)

if TYPE_CHECKING:
    from .._async_client import AsyncAnyAPI
    from .._client import AnyAPI


class FacebookAdsSearchInput(TypedDict, total=False):
    """Input for Facebook Ads Search."""

    query: Required[str]
    """Keyword to search the Meta Ad Library for (e.g. "protein powder")."""
    country: NotRequired[str]
    """Two-letter country code to scope results. Omit for all countries."""
    status: NotRequired[Literal["ALL", "ACTIVE", "INACTIVE"]]
    """Ad status filter. Default: ACTIVE."""
    mediaType: NotRequired[Literal["ALL", "IMAGE", "VIDEO", "MEME", "IMAGE_AND_MEME", "NONE"]]
    """Creative media type filter."""
    cursor: NotRequired[str]
    """Opaque pagination cursor from a previous response's nextCursor."""

class FacebookAdsSearchData(BaseModel):
    totalResults: int
    nextCursor: str
    ads: list[FacebookAdsSearchAd]

class FacebookAdsSearchAd(BaseModel):
    model_config = ConfigDict(extra="allow")

    id: str = Field(description="Ad Library archive ID. Populated whenever the provider returns data.")
    pageId: str = Field(description="Populated whenever the provider returns data.")
    pageName: str = Field(description="Populated whenever the provider returns data.")
    active: bool
    startDate: int = Field(description="Epoch seconds. Populated whenever the provider returns data.")
    endDate: int = Field(description="Epoch seconds.")
    text: str = Field(description="Ad body text. Populated whenever the provider returns data.")
    title: str = Field(description="Populated whenever the provider returns data.")
    ctaText: str = Field(description="Populated whenever the provider returns data.")
    ctaType: str = Field(description="Populated whenever the provider returns data.")
    linkUrl: str = Field(description="Populated whenever the provider returns data.")
    displayFormat: str = Field(description="Populated whenever the provider returns data.")
    platforms: list[str] = Field(description="Populated whenever the provider returns data.")
    adCount: int = Field(description="Number of ads in this campaign (collation count).")

class FacebookNamespace:
    """Typed methods for this platform. Attached lazily to the client."""

    def __init__(self, client: "AnyAPI") -> None:
        self._client = client

    def ads_search(self, *, options: RequestOptions | None = None, **input: Unpack[FacebookAdsSearchInput]) -> RunResult[FacebookAdsSearchData]:
        """Facebook Ads Search

        Search the Meta Ad Library by keyword and country, paging through active or
        inactive ads with an opaque cursor.

        Price: $0.002 per request.

        Example:
            res = client.facebook.ads_search(query="nike", country="US")
        """
        raw = self._client._run(  # pyright: ignore[reportPrivateUsage]
            "facebook.ads_search", dict(input), options
        )
        return RunResult[FacebookAdsSearchData].model_validate(raw.model_dump(by_alias=True))

    def iter_ads_search(self, *, options: RequestOptions | None = None, **input: Unpack[FacebookAdsSearchInput]) -> Paginator[FacebookAdsSearchAd, FacebookAdsSearchData]:
        """Iterate Facebook Ads Search results, following pagination cursors.

        Yields flattened items from the \`ads\` field of each page. Use
        \`.pages()\` on the returned paginator to walk whole \`RunResult\` pages.
        """
        return paginate(self._client, "facebook.ads_search", dict(input), "ads", options=options)

class AsyncFacebookNamespace:
    """Typed methods for this platform. Attached lazily to the client."""

    def __init__(self, client: "AsyncAnyAPI") -> None:
        self._client = client

    async def ads_search(self, *, options: RequestOptions | None = None, **input: Unpack[FacebookAdsSearchInput]) -> RunResult[FacebookAdsSearchData]:
        """Facebook Ads Search

        Search the Meta Ad Library by keyword and country, paging through active or
        inactive ads with an opaque cursor.

        Price: $0.002 per request.

        Example:
            res = client.facebook.ads_search(query="nike", country="US")
        """
        raw = await self._client._arun(  # pyright: ignore[reportPrivateUsage]
            "facebook.ads_search", dict(input), options
        )
        return RunResult[FacebookAdsSearchData].model_validate(raw.model_dump(by_alias=True))

    def iter_ads_search(self, *, options: RequestOptions | None = None, **input: Unpack[FacebookAdsSearchInput]) -> AsyncPaginator[FacebookAdsSearchAd, FacebookAdsSearchData]:
        """Iterate Facebook Ads Search results, following pagination cursors.

        Yields flattened items from the \`ads\` field of each page. Use
        \`.pages()\` on the returned paginator to walk whole \`RunResult\` pages.
        """
        return apaginate(self._client, "facebook.ads_search", dict(input), "ads", options=options)
