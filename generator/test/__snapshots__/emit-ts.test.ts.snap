  "sku-map.ts": "// Generated - do not edit. Regenerate with: pnpm generate

import type {
  AmazonReviewsData,
  AmazonReviewsInput,
} from "./platforms/amazon.js";
import type {
  FacebookAdsSearchData,
  FacebookAdsSearchInput,
} from "./platforms/facebook.js";
import type {
  ThreadsProfileData,
  ThreadsProfileInput,
} from "./platforms/threads.js";

/**
 * Maps every SKU slug literal to its input and data payload types. Powers the generic
 * \`client.run(slug, input)\` overload so the compiler infers the right shapes by slug.
 *
 * Emitted as a module augmentation of the handwritten core \`SkuMap\` (declaration
 * merging): the core interface carries a permissive string index (unknown slugs resolve
 * to RunResult<unknown>) and this file adds every concrete slug literal on top.
 */
declare module "../core/client.js" {
  interface SkuMap {
    "amazon.reviews": { input: AmazonReviewsInput; data: AmazonReviewsData };
    "facebook.ads_search": {
      input: FacebookAdsSearchInput;
      data: FacebookAdsSearchData;
    };
    "threads.profile": { input: ThreadsProfileInput; data: ThreadsProfileData };
  }
}

export type { SkuMap } from "../core/index.js";
",
