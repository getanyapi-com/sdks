{
  "name": "@anyapi/generator",
  "private": true,
  "version": "0.0.0",
  "description": "Internal codegen: openapi.json snapshot -> ir.json -> emitted TS + Python SDK sources. Not published.",
  "type": "module",
  "scripts": {
    "generate": "tsx src/index.ts",
    "fetch": "tsx src/index.ts fetch",
    "classify": "tsx src/classify-cli.ts",
    "version:current": "tsx src/bump-version.ts current",
    "version:next": "tsx src/bump-version.ts next",
    "version:apply": "tsx src/bump-version.ts apply",
    "test": "vitest run --config vitest.config.ts",
    "check": "tsc --noEmit && vitest run --config vitest.config.ts"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "ajv": "^8.17.1",
    "prettier": "^3.3.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  },
  "license": "MIT"
}
