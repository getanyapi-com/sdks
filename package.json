{
  "name": "anyapi-sdks",
  "private": true,
  "version": "0.0.0",
  "description": "Monorepo for the official AnyAPI typed SDKs (TypeScript + Python).",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "generate": "pnpm --filter @anyapi/generator generate",
    "generate:check": "pnpm --filter @anyapi/generator generate -- --check",
    "check": "pnpm -r --workspace-concurrency=1 run check"
  },
  "license": "MIT"
}
